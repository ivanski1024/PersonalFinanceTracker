{
  "name": "per-fin-tracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest",
    "test:server": "vitest --config vitest.server.config.ts",
    "test:all": "npm test -- --run && npm run test:server -- --run",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "dependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "express": "^5.2.1",
    "mongoose": "^9.3.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router": "^7.13.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@testing-library/cypress": "^10.1.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.4.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.0.3",
    "cypress": "^15.2.0",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jest": "^30.1.3",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.1.6",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.1.6",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --cache --fix"
  }
}
